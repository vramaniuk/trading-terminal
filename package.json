{
  "name": "@caffeine/template-app",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "dev:frontend": "cd src/frontend && pnpm dev",
    "dev:backend": "cd src/backend && pnpm dev",
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "build:frontend": "cd src/frontend && pnpm build",
    "build:backend": "cd src/backend && pnpm build",
    "build": "pnpm build:frontend && pnpm build:backend",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm -r --if-present run check",
    "fix": "pnpm -r --if-present run fix"
  },
  "devDependencies": {
    "sharp": "^0.34.4",
    "concurrently": "^8.2.2"
  },
  "dependencies": {}
}
